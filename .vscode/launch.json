{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch GoMad Web",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build web",
      "program": "${workspaceFolder}/bin/Debug/net8.0/GoMad.dll",
      "args": [
        "--urls",
        "http://127.0.0.1:5057"
      ],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "Now listening on:\\s+(https?://\\S+)"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    }
  ]
}