{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "restore web",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "restore",
        "GoMad.sln"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "build web",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "GoMad.sln",
        "-c",
        "Debug"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "restore web",
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "run web",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "GoMad.csproj",
        "--urls",
        "http://127.0.0.1:5057"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "build web",
      "isBackground": true,
      "problemMatcher": [
        {
          "base": "$msCompile",
          "background": {
            "activeOnStart": true,
            "beginsPattern": "^Building(?:\.\.\.)?$",
            "endsPattern": "Now listening on:\\s+http://127.0.0.1:5057"
          }
        }
      ]
    },
    {
      "label": "build mobile apk",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "publish",
        "GoMad.Mobile\\GoMad.Mobile.csproj",
        "-f",
        "net10.0-android",
        "-c",
        "Release",
        "-o",
        "./artifacts/android"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": false
      }
    }
  ]
}